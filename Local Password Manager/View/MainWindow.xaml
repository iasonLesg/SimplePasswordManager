<Window x:Class="Local_Password_Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Password_Manager"
        mc:Ignorable="d"
        Title="Password Manager"
        WindowStyle="None"
        WindowState="Maximized"
        AllowsTransparency="True"
        Background="Transparent" 
        Topmost="False"
        ShowInTaskbar="True">

    <Window.InputBindings>
        <KeyBinding Key="I" Modifiers="Control" Command="{Binding BindDataCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#1E2A38"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Foreground" Value="#4FD1C5"/>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#1E2A38"/>
            <Setter Property="Foreground" Value="#4FD1C5"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>

        <Grid Name="MainAppContainer" Visibility="Hidden" Background="#0F1722" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E2A38" Padding="20" Opacity="0.95">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="5" Opacity="0.3"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="My Vault" Foreground="#4FD1C5" FontSize="28" FontWeight="Bold" Margin="0,0,0,40" HorizontalAlignment="Center"/>

                    <Button Name="AddPassBtn" Content="➕ Add Password" Click="AddPass" 
                            Style="{StaticResource ModernButton}" Margin="0,0,0,15"/>

                    <Button Name="DeletPass" Content="🗑️ Delete Mode" Click="DeletePass" 
                            Style="{StaticResource ModernButton}" Foreground="#ff6b6b" Visibility="Hidden"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Name="SearchBox" Grid.Column="0" Background="#1E2A38" CornerRadius="8" Width="400" Margin="0,0,15,0">
                        <Grid>
                            <TextBlock Text="🔎" FontSize="18" Foreground="#4FD1C5" VerticalAlignment="Center" Margin="15,0,0,0"/>
                            <TextBox Name="SearchTxt" TextChanged="SearchTxt_TextChanged" 
                     Background="Transparent" CaretBrush="White" Foreground="#4FD1C5" BorderThickness="0" FontSize="18" 
                     Margin="45,10,10,10" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Button Name="ToggleViewBtn" Grid.Column="1" Click="ToggleView_Click" Margin="0,0,15,0" Width="50" Height="50" Background="#1E2A38" Cursor="Hand" BorderThickness="0" ToolTip="Change View">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <TextBlock Text="☰" FontSize="24" Foreground="#4FD1C5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Name="SettingsBtn" Grid.Column="2" Click="Settings_Click" Width="50" Height="50" Background="#1E2A38" Cursor="Hand" BorderThickness="0" ToolTip="Settings">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                    <TextBlock Text="⚙" FontSize="24" Foreground="#4FD1C5" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <Border Name="PasswordsPanel" Grid.Row="1" Visibility="Visible">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="BorderContainer"/>
                    </ScrollViewer>
                </Border>

                <Border Name="AddPassGrid" Grid.Row="1" Background="#0F1722" Visibility="Hidden" CornerRadius="10">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                        <TextBlock Text="Add New Entry" Foreground="#4FD1C5" FontSize="35" FontWeight="Bold" TextAlignment="Center" Margin="0,0,0,40"/>

                        <TextBlock Text="Site Name" Foreground="#4FD1C5" FontSize="18" Margin="0,0,0,5" TextAlignment="Center"/>
                        <TextBox Name="TxtSiteName" Height="50" FontSize="22" Foreground="Wheat" Background="#1E2A38" 
                 BorderThickness="0" Padding="10" Margin="0,0,0,25"
                 TextAlignment="Center" VerticalContentAlignment="Center"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                            <TextBlock Text="Password" Foreground="#4FD1C5" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>

                            <Button Click="GeneratePass" ToolTip="Generate Password" Width="35" Height="35" Cursor="Hand" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBorder" Background="#1f2833" CornerRadius="17.5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="False">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="#1f2833"/>
                                                <Setter Property="Foreground" Value="#ed601a"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="#2D3A4A"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                                <Viewbox Width="35" Height="35">
                                    <TextBlock Text="♻" FontSize="30" FontWeight="Bold" Margin="0,-5,0,0"/>
                                </Viewbox>
                            </Button>
                        </StackPanel>

                        <TextBox Name="TxtPassword" Height="50" FontSize="22" Foreground="Wheat" Background="#1E2A38" 
                 BorderThickness="0" Padding="10" Margin="0,0,0,40"
                 TextAlignment="Center" VerticalContentAlignment="Center"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="15"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" Click="Back" Height="50" Cursor="Hand" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBorder" Background="#ab0722" CornerRadius="8">
                                            <ContentPresenter x:Name="Presenter" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                              Content="Back" TextBlock.FontWeight="Bold" TextBlock.FontSize="20" TextBlock.Foreground="White"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="White"/>
                                                <Setter TargetName="Presenter" Property="TextElement.Foreground" Value="#ab0722"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Grid.Column="2" Click="Save" Height="50" Cursor="Hand" BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBorder" Background="#4FD1C5" CornerRadius="8">
                                            <ContentPresenter x:Name="Presenter" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                              Content="Save" TextBlock.FontWeight="Bold" TextBlock.FontSize="20" TextBlock.Foreground="#0F1722"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="White"/>
                                                <Setter TargetName="Presenter" Property="TextElement.Foreground" Value="#4FD1C5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,30,15,0" Width="35" Height="35">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
            </Border.Effect>
            <Button Name="ToggleVaultBtn" Content="🔒" Click="ToggleVault_Click" 
                    Background="#1E2A38" Foreground="#4FD1C5" FontSize="22" BorderThickness="0" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,2"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Border>

        <Border Name="SaveBorder" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,30,100,0"
                Background="#1E2A38" CornerRadius="8" Padding="15,10" Visibility="Hidden">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
            </Border.Effect>
            <TextBlock Name="SaveText" Text="Password Copied ✅" FontSize="18" FontWeight="Bold" Foreground="#4fd16b" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
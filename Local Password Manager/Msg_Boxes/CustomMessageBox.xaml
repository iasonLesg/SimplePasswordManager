<Window x:Class="Local_Password_Manager.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message" Width="450" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" Topmost="True">

    <Window.Resources>
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#1E2A38"/>
            <Setter Property="Foreground" Value="#4FD1C5"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#0F1722" CornerRadius="12" BorderBrush="#1E2A38" BorderThickness="2" Margin="20">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="5" Opacity="0.6"/>
        </Border.Effect>

        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Name="IconBlock" Text="⚠️" FontSize="45" Foreground="#ff6b6b" VerticalAlignment="Center" Margin="0,0,20,0"/>

                <TextBlock Grid.Column="1" Name="MessageBlock" Text="Default Message" Foreground="Wheat" FontSize="20" 
                           TextWrapping="Wrap" VerticalAlignment="Center" LineHeight="28"/>
            </Grid>

            <Button Grid.Row="1" Content="OK" Click="OK_Click" 
                    Style="{StaticResource ModernButton}" 
                    Background="#4FD1C5" Foreground="#0F1722" 
                    HorizontalAlignment="Right" Width="100"/>
        </Grid>
    </Border>
</Window>
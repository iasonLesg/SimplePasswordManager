<Window x:Class="Local_Password_Manager.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login" Height="450" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Border Background="#0F1722" CornerRadius="15" BorderBrush="#1E2A38" BorderThickness="2" Margin="10">
        <StackPanel VerticalAlignment="Center" Margin="40,30,40,30">

            <TextBlock Text="🔒" FontSize="50" Foreground="#4FD1C5" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <StackPanel x:Name="SetupPanel" Visibility="Collapsed">
                <TextBlock Text="Set Master Password" Foreground="White" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,10" TextAlignment="Center"/>
                <TextBlock Text="Stored locally. If lost, your data is gone forever." 
                           Foreground="#8892A8" FontSize="13" TextWrapping="Wrap" Margin="0,0,0,25" TextAlignment="Center"/>
                <PasswordBox Name="TxtCreateMaster" Height="45" Background="#18212D" Foreground="White" BorderThickness="0" 
                             Margin="0,0,0,25" Padding="10" VerticalContentAlignment="Center" CaretBrush="White"/>
            </StackPanel>

            <StackPanel x:Name="LoginPanel" Visibility="Collapsed">
                <TextBlock Text="Welcome Back" Foreground="White" FontSize="26" FontWeight="SemiBold" Margin="0,0,0,30" TextAlignment="Center"/>
                <PasswordBox Name="TxtLoginMaster" Height="45" Background="#18212D" Foreground="White" BorderThickness="0" 
                             Margin="0,0,0,30" Padding="10" VerticalContentAlignment="Center" CaretBrush="White"/>
                <TextBlock x:Name="ErrorMsg" Text="Wrong password" Foreground="#FF6B6B" Visibility="Collapsed" 
               HorizontalAlignment="Center" Margin="0,0,0,10" FontWeight="Bold"/>
            </StackPanel>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Click="Exit_Click" Height="45" Cursor="Hand" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" Background="#18212D" CornerRadius="6">
                                <ContentPresenter x:Name="Presenter" Content="Exit" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      TextBlock.Foreground="#FF6B6B" TextBlock.FontWeight="Bold"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="#FF6B6B"/>
                                    <Setter TargetName="Presenter" Property="TextElement.Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="2" Name="BtnAction" IsDefault="True" Click="Action_Click" Height="45" Cursor="Hand" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BtnBorder" Background="#4FD1C5" CornerRadius="6">
                                <ContentPresenter x:Name="Presenter" Content="{TemplateBinding Content}" 
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      TextBlock.Foreground="#0F1722" TextBlock.FontWeight="Bold"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BtnBorder" Property="Background" Value="White"/>
                                    <Setter TargetName="Presenter" Property="TextElement.Foreground" Value="#4FD1C5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</Window>